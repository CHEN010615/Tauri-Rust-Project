{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PluginCore",
  "version": "0.1.0",
  "identifier": "com.chen.plugin-core.tauri",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PluginCore",
        "width": 1280,
        "height": 850,
        "minWidth": 1180,
        "minHeight": 850,
        "decorations": true,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"]
  }
}
